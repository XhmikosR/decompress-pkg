{
  "name": "@xhmikosr/decompress-pkg",
  "version": "0.1.0",
  "description": "macOS .pkg (XAR) archive decompress plugin",
  "keywords": [
    "cpio",
    "decompress",
    "decompressplugin",
    "extract",
    "installer",
    "macos",
    "payload",
    "pkg",
    "xar"
  ],
  "homepage": "https://github.com/XhmikosR/decompress-pkg#readme",
  "bugs": {
    "url": "https://github.com/XhmikosR/decompress-pkg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XhmikosR/decompress-pkg.git"
  },
  "license": "MIT",
  "author": "XhmikosR <xhmikosr@gmail.com>",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "main": "index.js",
  "files": [
    "cpio.js",
    "index.js"
  ],
  "scripts": {
    "ava": "ava",
    "lint": "xo",
    "xo": "xo",
    "fix": "xo --fix",
    "test": "npm run xo && npm run ava",
    "test-ci": "c8 ava"
  },
  "dependencies": {
    "fast-xml-parser": "^5.10.1"
  },
  "devDependencies": {
    "ava": "^7.0.0",
    "c8": "^12.0.0",
    "xo": "^2.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "xo": {
    "space": 2,
    "rules": {
      "capitalized-comments": "off",
      "require-unicode-regexp": "off",
      "unicorn/prevent-abbreviations": "off"
    }
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  }
}
